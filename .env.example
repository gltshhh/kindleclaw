PORT=5000
AGENDA_PATH=./data/agenda.md
OUTPUT_PATH=./output/kindle.png

# OPCJONALNE: auto-sync z plikiem TASKS.md (master list zadań).
# Jeśli ustawione, przed każdym renderem agenda.md jest regenerowana z TASKS.md
# (sekcje "PILNE" i "PROJEKTY W TOKU"). Jeśli puste - sync wyłączony, agenda.md
# edytujesz/agent edytuje ręcznie.
# Ścieżka bezwzględna lub względna do katalogu kindleclaw.
# Przykłady:
#   TASKS_PATH=/home/jakub/workspace/TASKS.md
#   TASKS_PATH=../../TASKS.md
#   TASKS_PATH=./data/TASKS.md
TASKS_PATH=
TASKS_LIMIT=5

# Kindle 4 D01100 (non-touch, 6") = 600x800
# PW2 = 758x1024, PW3/4/5 = 1072x1448, Oasis = 1264x1680, Scribe = 1860x2480
WIDTH=600
HEIGHT=800

ROTATION=0
GRAYSCALE_DEPTH=8
COLOR_MODE=GrayScale
CONTRAST=1
DITHER=false

# Pusty = brak crona (push-on-demand). Przyklad cyklicznego: */20 * * * *
CRON_JOB=

RENDERING_DELAY=0
RENDERING_TIMEOUT=10000
BROWSER_LAUNCH_TIMEOUT=30000
